# =============================================================================
# ~/.config/ghostty/config — managed by dotfiles (stow package: ghostty)
# Reload in-app with: Cmd+Shift+,    Docs: https://ghostty.org/docs/config
# =============================================================================

# --- Shell -------------------------------------------------------------------
# Use the Homebrew zsh and enable shell integration (cwd tracking, prompt marks).
command = /bin/zsh -l
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- Font --------------------------------------------------------------------
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true

# --- Theme / appearance ------------------------------------------------------
# Follow macOS appearance automatically (light in the day, dark at night).
theme = light:catppuccin-latte,dark:catppuccin-mocha
background-opacity = 0.96
background-blur-radius = 20
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
cursor-style = block
mouse-hide-while-typing = true
# Dim the inactive split so the focused pane (e.g. the running agent) is obvious.
unfocused-split-opacity = 0.80
resize-overlay = never                    # no distracting size popups while splitting

# --- macOS behaviour ---------------------------------------------------------
macos-option-as-alt = true                # left/right Option send Esc+ for shells
macos-titlebar-style = transparent
window-save-state = always                # restore windows/tabs after quit
quit-after-last-window-closed = true
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard
# New splits/tabs inherit the cwd — open a split and you're still in the repo
# (or still inside the container shell, via Ghostty's shell integration).
window-inherit-working-directory = true

# Let the OS surface a notification when a long agent/build run finishes while
# the pane is in the background (uses OSC 9 / 777 from shell integration).
desktop-notifications = true

# Ghostty is managed by Homebrew — disable the in-app updater so the two don't
# fight. `brew upgrade --cask ghostty` (or update-mac.sh) keeps it current.
auto-update = off

# --- Scrollback --------------------------------------------------------------
scrollback-limit = 10000000               # ~10MB; agent output gets long

# --- Keybindings -------------------------------------------------------------
# Splits + tabs for juggling devcontainer exec / agent / ollama panes.
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
keybind = cmd+w=close_surface
keybind = cmd+t=new_tab
keybind = cmd+left_bracket=goto_split:previous
keybind = cmd+right_bracket=goto_split:next
keybind = cmd+enter=toggle_split_zoom
keybind = cmd+k=clear_screen               # clear scrollback in the focused pane
keybind = cmd+shift+p=toggle_command_palette  # fuzzy action search (recent Ghostty)

# Global drop-down "quick terminal" — summon a scratch shell from anywhere
# (run a quick `op`/`olp`/`gh` command without leaving your editor) and dismiss.
keybind = global:cmd+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-animation-duration = 0.12
